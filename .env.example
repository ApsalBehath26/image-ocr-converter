# Flask Configuration
FLASK_APP=app.main
FLASK_ENV=production
HOST=0.0.0.0
PORT=5000

# Upload Configuration
UPLOAD_FOLDER=/app/uploads
MAX_CONTENT_LENGTH=10485760

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Tesseract Configuration
TESSERACT_CMD=/usr/bin/tesseract

# Logging
LOG_LEVEL=INFO
